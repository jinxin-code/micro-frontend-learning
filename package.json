    "start:static": "pnpm --filter static-app serve",
    "start:vanilla": "pnpm --filter main-vanilla serve",
    "start:main-react": "pnpm --filter main-react dev",
    "start:umi": "pnpm --filter main-umi dev",
    "start:angular": "pnpm --filter main-angular dev",
    "start:midway": "pnpm --filter main-midway dev"
  },
  "keywords": [
    "qiankun",
    "micro-frontend",
