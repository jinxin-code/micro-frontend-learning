  "description": "qiankun 微前端教学项目 - 多技术栈主应用对比学习",
  "private": true,
  "scripts": {
    "install:all": "pnpm install",
    "start:main": "pnpm --filter main-app dev",
    "start:react": "pnpm --filter react-app dev",
